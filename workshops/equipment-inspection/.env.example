# Backend — copy to .env and fill in from terraform output
S3_BUCKET=equipment-inspection-<your-slug>-photos
DYNAMODB_TABLE=equipment-inspection-<your-slug>
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>

# Frontend — copy to frontend/.env.local if running backend on a different host
# Leave blank when using vite proxy (default for local dev)
VITE_API_URL=
